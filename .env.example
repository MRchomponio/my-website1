# Get these from your Supabase project: Settings → API Keys
# https://supabase.com/dashboard/project/_/settings/api-keys

NEXT_PUBLIC_SUPABASE_URL=https://necdqtirygnsecqyvogg.supabase.co

# Publishable key — safe to expose in the browser. Used by both the
# browser and server Supabase clients. Data access is enforced by
# Row Level Security policies, not by keeping this secret.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_R194a_38E1Q_YhXWxx2aUw_RtUUVX9h

# Secret key — server-only, NEVER prefix with NEXT_PUBLIC_, never send
# to the browser. Used only by createAdminClient() in
# src/lib/supabase/server.ts for trusted moderation/admin operations
# that must bypass RLS.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxx
